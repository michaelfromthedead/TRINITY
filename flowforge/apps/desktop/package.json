{
  "name": "@flowforge/desktop",
  "version": "0.1.0",
  "description": "FlowForge Desktop Application",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist src-tauri/target",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "tsx scripts/integration-test.ts",
    "test:integration:debug": "DEBUG=1 tsx scripts/integration-test.ts",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "dependencies": {
    "@flowforge/core": "workspace:*",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@vueuse/core": "^11.3.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cva": "npm:class-variance-authority@^0.7.0",
    "es-toolkit": "^1.24.0",
    "lodash-es": "^4.17.21",
    "pinia": "^2.1.0",
    "primevue": "^4.2.0",
    "radix-vue": "^1.9.0",
    "reka-ui": "^2.0.0",
    "tailwind-merge": "^2.5.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.0.0"
  }
}
