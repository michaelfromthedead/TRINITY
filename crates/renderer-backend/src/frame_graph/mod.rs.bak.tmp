    #[test]
    fn test_ir_pass_sync_access_set() {
        let ca = ColorAttachment {
            resource: ResourceHandle(5),
            load_op: AttachmentLoadOp::Load,
            store_op: AttachmentStoreOp::Store,
            ..Default::default()
        };
        let pass = IrPass::graphics(
            PassIndex(0),
            "test",
            vec![ca],
