        let buf1 = &alloc.buffers[&ResourceHandle(1)];
        let buf2 = &alloc.buffers[&ResourceHandle(2)];
        assert_eq!(buf1, buf2, "non-overlapping transient buffers should alias");
    }

    #[test]
    fn test_allocate_resource_handle_not_in_lifetimes() {
